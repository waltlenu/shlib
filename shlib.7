.\" shlib - A library of reusable Bash shell functions
.TH SHLIB 7 "April 2026" "shlib 0.6.0" "Bash Library"
.SH NAME
shlib \- A library of reusable Bash shell functions
.SH SYNOPSIS
.B source
.I /path/to/shlib.bash
.SH DESCRIPTION
.B shlib
is a library of reusable Bash functions that can be sourced into shell scripts.
It provides common utilities for arrays, strings, logging, ANSI colors,
key\-value stores, and other frequently needed operations.
.PP
The library is distributed as a single file
.RB ( shlib.bash )
for easy download and sourcing.
It is pure Bash with no external binary dependencies wherever possible.
.PP
All functions are namespaced with the
.B shlib::
prefix, and all global variables are namespaced with the
.B SHLIB_
prefix, to avoid polluting the caller's environment.
.PP
The library enables strict mode
.RB ( "set \-euo pipefail" )
when sourced.
It includes double\-source protection via the
.B SHLIB_LOADED
variable to prevent loading multiple times.
.SH REQUIREMENTS
.B shlib
requires Bash version 3 or higher.
The key\-value (KV) section requires Bash version 4 or higher
for associative array support.
The library will fail to load with an error message
if sourced in an older version of Bash.

.SH _CORE
.SS shlib::list_functions
.PP
List all shlib functions
.PP
\fBStdout:\fR One function name per line, sorted alphabetically
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.SS shlib::list_variables
.PP
List all shlib global variables
.PP
\fBStdout:\fR One variable name per line, sorted alphabetically
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.SS shlib::version
.PP
Print the library version
.PP
\fBStdout:\fR The version string
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds

.SH ARRAYS
.SS shlib::arr_append
.BI "shlib::arr_append " "string" " " "string"
.PP
Append one or more elements to an array
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the array variable (without $)
.TP
\fI$@\fR (string)
Elements to append
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
my_array=(a b)
shlib::arr_append my_array c d
# my_array is now (a b c d)
.fi
.RE
.SS shlib::arr_delete
.BI "shlib::arr_delete " "string" " " "int"
.PP
Delete an element from an array by index
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the array variable (without $)
.TP
\fI$2\fR (int)
The index to delete
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
my_array=(a b c d)
shlib::arr_delete my_array 1
# my_array is now (a c d)
.fi
.RE
.SS shlib::arr_insert
.BI "shlib::arr_insert " "string" " " "int" " " "string"
.PP
Insert an element at a specific index in an array
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the array variable (without $)
.TP
\fI$2\fR (int)
The index at which to insert
.TP
\fI$3\fR (string)
The element to insert
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
my_array=(a b c d)
shlib::arr_insert my_array 2 "X"
# my_array is now (a b X c d)
.fi
.RE
.SS shlib::arr_len
.BI "shlib::arr_len " "string"
.PP
Get the number of elements in an array
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the array variable (without $)
.PP
\fBStdout:\fR The number of elements in the array
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
my_array=(a b c d e)
shlib::arr_len my_array  # outputs 5
.fi
.RE
.SS shlib::arr_merge
.BI "shlib::arr_merge " "string" " " "string"
.PP
Merge multiple arrays into a destination array
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the destination array variable (without $)
.TP
\fI$@\fR (string)
Names of source arrays to merge (without $)
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
arr1=(a b)
arr2=(c d)
arr3=(e f)
shlib::arr_merge result arr1 arr2 arr3
# result is now (a b c d e f)
.fi
.RE
.SS shlib::arr_pop
.BI "shlib::arr_pop " "string"
.PP
Remove the last element from an array
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the array variable (without $)
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
my_array=(a b c d)
shlib::arr_pop my_array
# my_array is now (a b c)
.fi
.RE
.SS shlib::arr_print
.BI "shlib::arr_print " "string" " " "string"
.PP
Print array elements on one line with a separator
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the array variable (without $)
.TP
\fI$2\fR (string)
The separator (default: " ")
.PP
\fBStdout:\fR Array elements joined by separator
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
my_array=(a b c)
shlib::arr_print my_array      # outputs "a b c"
shlib::arr_print my_array ","  # outputs "a,b,c"
.fi
.RE
.SS shlib::arr_printn
.BI "shlib::arr_printn " "string"
.PP
Print array elements one per line
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the array variable (without $)
.PP
\fBStdout:\fR Each array element on its own line
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
my_array=(a b c)
shlib::arr_printn my_array
# outputs:
# a
# b
# c
.fi
.RE
.SS shlib::arr_reverse
.BI "shlib::arr_reverse " "string"
.PP
Reverse an array in place
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the array variable (without $)
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
my_array=(a b c d)
shlib::arr_reverse my_array
# my_array is now (d c b a)
.fi
.RE
.SS shlib::arr_sort
.BI "shlib::arr_sort " "string"
.PP
Sort an array in place (lexicographic order)
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the array variable (without $)
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
my_array=(cherry apple banana)
shlib::arr_sort my_array
# my_array is now (apple banana cherry)
.fi
.RE
.SS shlib::arr_uniq
.BI "shlib::arr_uniq " "string"
.PP
Remove duplicate elements from an array (keeps first occurrence)
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the array variable (without $)
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
my_array=(a b a c b d)
shlib::arr_uniq my_array
# my_array is now (a b c d)
.fi
.RE

.SH DT
.SS shlib::dt_add
.BI "shlib::dt_add " "int" " " "int" " " "string"
.PP
Add time units to timestamp
.PP
\fBArguments:\fR
.TP
\fI$1\fR (int)
Unix timestamp
.TP
\fI$2\fR (int)
Amount to add (can be negative)
.TP
\fI$3\fR (string)
Unit: seconds, minutes, hours, days, weeks
.PP
\fBStdout:\fR New Unix timestamp
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
shlib::dt_add 1704067200 1 days    # add 1 day
shlib::dt_add 1704067200 -2 hours  # subtract 2 hours
.fi
.RE
.SS shlib::dt_diff
.BI "shlib::dt_diff " "int" " " "int" " " "string"
.PP
Calculate difference between timestamps
.PP
\fBArguments:\fR
.TP
\fI$1\fR (int)
First Unix timestamp
.TP
\fI$2\fR (int)
Second Unix timestamp
.TP
\fI$3\fR (string)
Optional unit: seconds (default), minutes, hours, days, weeks
.PP
\fBStdout:\fR Difference (ts1 - ts2) in specified unit (integer division)
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
shlib::dt_diff 1704153600 1704067200          # outputs: 86400 (seconds)
shlib::dt_diff 1704153600 1704067200 hours    # outputs: 24
shlib::dt_diff 1704153600 1704067200 days     # outputs: 1
.fi
.RE
.SS shlib::dt_duration
.BI "shlib::dt_duration " "int" " " "string"
.PP
Format seconds as human-readable duration
.PP
\fBArguments:\fR
.TP
\fI$1\fR (int)
Number of seconds
.TP
\fI$2\fR (string)
Optional format: short (default), long, compact
.PP
\fBStdout:\fR Human-readable duration string
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
shlib::dt_duration 90061              # outputs: 1d 1h 1m 1s
shlib::dt_duration 90061 long         # outputs: 1 day, 1 hour, 1 minute, 1 second
shlib::dt_duration 90061 compact      # outputs: 1d1h1m1s
.fi
.RE
.SS shlib::dt_elapsed
.BI "shlib::dt_elapsed " "int" " " "string"
.PP
Format elapsed time since start timestamp
.PP
\fBArguments:\fR
.TP
\fI$1\fR (int)
Start Unix timestamp
.TP
\fI$2\fR (string)
Optional format: short (default), long, compact
.PP
\fBStdout:\fR Elapsed time as human-readable duration
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
start=$(shlib::dt_now)
sleep 5
shlib::dt_elapsed "$start"  # outputs: 5s
.fi
.RE
.SS shlib::dt_from_unix
.BI "shlib::dt_from_unix " "int" " " "string"
.PP
Format Unix timestamp with format string
.PP
\fBArguments:\fR
.TP
\fI$1\fR (int)
Unix timestamp
.TP
\fI$2\fR (string)
Format string (strftime compatible)
.PP
\fBStdout:\fR Formatted date/time string
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Success
.TP
\fB1\fR
Invalid timestamp or format
.PP
\fBExample:\fR
.RS
.nf
shlib::dt_from_unix 1704067200 "%Y-%m-%d"  # outputs: 2024-01-01
shlib::dt_from_unix 1704067200 "%H:%M:%S"  # outputs: 12:00:00
.fi
.RE
.SS shlib::dt_is_after
.BI "shlib::dt_is_after " "int" " " "int"
.PP
Check if timestamp A is after timestamp B
.PP
\fBArguments:\fR
.TP
\fI$1\fR (int)
First Unix timestamp
.TP
\fI$2\fR (int)
Second Unix timestamp
.PP
\fBExit codes:\fR
.TP
\fB0\fR
ts1 > ts2
.TP
\fB1\fR
ts1 <= ts2
.PP
\fBExample:\fR
.RS
.nf
shlib::dt_is_after 1704153600 1704067200 && echo "later"
.fi
.RE
.SS shlib::dt_is_before
.BI "shlib::dt_is_before " "int" " " "int"
.PP
Check if timestamp A is before timestamp B
.PP
\fBArguments:\fR
.TP
\fI$1\fR (int)
First Unix timestamp
.TP
\fI$2\fR (int)
Second Unix timestamp
.PP
\fBExit codes:\fR
.TP
\fB0\fR
ts1 < ts2
.TP
\fB1\fR
ts1 >= ts2
.PP
\fBExample:\fR
.RS
.nf
shlib::dt_is_before 1704067200 1704153600 && echo "earlier"
.fi
.RE
.SS shlib::dt_now
.PP
Get current Unix timestamp
.PP
\fBStdout:\fR The current Unix timestamp in seconds
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
shlib::dt_now  # outputs: 1704067200
.fi
.RE
.SS shlib::dt_now_iso
.BI "shlib::dt_now_iso " "string"
.PP
Get current datetime in ISO 8601 format
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
Optional: "local" for local time, default is UTC
.PP
\fBStdout:\fR Current datetime in ISO 8601 format
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
shlib::dt_now_iso         # outputs: 2024-01-01T12:00:00Z
shlib::dt_now_iso local   # outputs: 2024-01-01T07:00:00-05:00
.fi
.RE
.SS shlib::dt_today
.PP
Get current date as YYYY-MM-DD
.PP
\fBStdout:\fR Current date in YYYY-MM-DD format
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
shlib::dt_today  # outputs: 2024-01-01
.fi
.RE

.SH KV
.SS shlib::kv_clear
.BI "shlib::kv_clear " "string"
.PP
Remove all entries from an associative array
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the associative array variable (without $)
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
declare -A config
config[host]="localhost"
config[port]="8080"
shlib::kv_clear config
.fi
.RE
.SS shlib::kv_copy
.BI "shlib::kv_copy " "string" " " "string"
.PP
Copy an associative array to another
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the destination associative array (without $)
.TP
\fI$2\fR (string)
The name of the source associative array (without $)
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
declare -A original
original[host]="localhost"
declare -A copy
shlib::kv_copy copy original
.fi
.RE
.SS shlib::kv_delete
.BI "shlib::kv_delete " "string" " " "string"
.PP
Delete a key from an associative array
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the associative array variable (without $)
.TP
\fI$2\fR (string)
The key to delete
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
declare -A config
config[host]="localhost"
shlib::kv_delete config "host"
.fi
.RE
.SS shlib::kv_exists
.BI "shlib::kv_exists " "string" " " "string"
.PP
Check if a key exists in an associative array
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the associative array variable (without $)
.TP
\fI$2\fR (string)
The key to check
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Key exists
.TP
\fB1\fR
Key does not exist
.PP
\fBExample:\fR
.RS
.nf
declare -A config
config[host]="localhost"
shlib::kv_exists config "host" && echo "exists"
.fi
.RE
.SS shlib::kv_find
.BI "shlib::kv_find " "string" " " "string" " " "string"
.PP
Find all keys with a specific value
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the destination array variable (without $)
.TP
\fI$2\fR (string)
The name of the associative array variable (without $)
.TP
\fI$3\fR (string)
The value to search for
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
declare -A roles
roles[alice]="admin"
roles[bob]="user"
roles[carol]="admin"
shlib::kv_find admins roles "admin"
# admins is now: alice carol
.fi
.RE
.SS shlib::kv_get
.BI "shlib::kv_get " "string" " " "string"
.PP
Get a value by key from an associative array
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the associative array variable (without $)
.TP
\fI$2\fR (string)
The key to look up
.PP
\fBStdout:\fR The value associated with the key
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Key exists
.TP
\fB1\fR
Key not found
.PP
\fBExample:\fR
.RS
.nf
declare -A config
config[host]="localhost"
shlib::kv_get config "host"  # outputs: localhost
.fi
.RE
.SS shlib::kv_get_default
.BI "shlib::kv_get_default " "string" " " "string" " " "string"
.PP
Get a value by key with a fallback default
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the associative array variable (without $)
.TP
\fI$2\fR (string)
The key to look up
.TP
\fI$3\fR (string)
The default value if key not found
.PP
\fBStdout:\fR The value associated with the key, or default if not found
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
declare -A config
shlib::kv_get_default config "port" "8080"  # outputs: 8080
.fi
.RE
.SS shlib::kv_has_value
.BI "shlib::kv_has_value " "string" " " "string"
.PP
Check if a value exists in an associative array
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the associative array variable (without $)
.TP
\fI$2\fR (string)
The value to search for
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Value exists
.TP
\fB1\fR
Value does not exist
.PP
\fBExample:\fR
.RS
.nf
declare -A config
config[host]="localhost"
shlib::kv_has_value config "localhost" && echo "found"
.fi
.RE
.SS shlib::kv_keys
.BI "shlib::kv_keys " "string" " " "string"
.PP
Get all keys from an associative array into a regular array
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the destination array variable (without $)
.TP
\fI$2\fR (string)
The name of the associative array variable (without $)
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
declare -A config
config[host]="localhost"
config[port]="8080"
shlib::kv_keys keys config
# keys is now an array of: host port (order may vary)
.fi
.RE
.SS shlib::kv_len
.BI "shlib::kv_len " "string"
.PP
Get the count of entries in an associative array
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the associative array variable (without $)
.PP
\fBStdout:\fR The number of key-value pairs
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
declare -A config
config[host]="localhost"
config[port]="8080"
shlib::kv_len config  # outputs: 2
.fi
.RE
.SS shlib::kv_map
.BI "shlib::kv_map " "string" " " "string"
.PP
Apply a transformation command to all values
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the associative array variable (without $)
.TP
\fI$2\fR (string)
The command to apply (receives value via stdin, outputs to stdout)
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
declare -A data
data[name]="hello"
data[greeting]="world"
shlib::kv_map data 'tr a-z A-Z'
# data is now: name=HELLO greeting=WORLD
.fi
.RE
.SS shlib::kv_merge
.BI "shlib::kv_merge " "string" " " "string"
.PP
Merge multiple associative arrays (later arrays override earlier)
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the destination associative array (without $)
.TP
\fI$@\fR (string)
Names of source associative arrays to merge (without $)
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
declare -A defaults
defaults[host]="localhost"
defaults[port]="80"
declare -A overrides
overrides[port]="8080"
declare -A result
shlib::kv_merge result defaults overrides
# result is now: host=localhost port=8080
.fi
.RE
.SS shlib::kv_print
.BI "shlib::kv_print " "string" " " "string" " " "string"
.PP
Print key-value pairs on one line with separators
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the associative array variable (without $)
.TP
\fI$2\fR (string)
Key-value separator (default: "=")
.TP
\fI$3\fR (string)
Pair separator (default: " ")
.PP
\fBStdout:\fR Key-value pairs joined by separators
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
declare -A config
config[host]="localhost"
config[port]="8080"
shlib::kv_print config           # outputs: host=localhost port=8080
shlib::kv_print config ":" ", "  # outputs: host:localhost, port:8080
.fi
.RE
.SS shlib::kv_printn
.BI "shlib::kv_printn " "string" " " "string"
.PP
Print key-value pairs one per line
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The name of the associative array variable (without $)
.TP
\fI$2\fR (string)
Key-value separator (default: "=")
.PP
\fBStdout:\fR Each key-value pair on its own line
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Always succeeds
.PP
\fBExample:\fR
.RS
.nf
declare -A config
config[host]="localhost"
config[port]="8080"
shlib::kv_printn config
# outputs:
# host=localhost
# port=8080
.fi
.RE
.SS shlib::kv_set
.BI "shlib::kv_set " "string" " " "string" " " "string"
.PP
Set a key-value pair in an associative array
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
