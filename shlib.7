.SH SYSTEM
.SS shlib::cmd_exists
.BI "shlib::cmd_exists " "string"
.PP
Check if a command exists in PATH
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
The command name to check
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Command exists
.TP
\fB1\fR
Command not found
.PP
\fBExample:\fR
.RS
.nf
shlib::cmd_exists git
.fi
.RE
.SS shlib::cmd_locked
.BI "shlib::cmd_locked " "string" " " "int" " " "string"
.PP
Run a command protected by file-based locking
.PP
\fBArguments:\fR
.TP
\fI$1\fR (string)
Path to the lock file (a .lock directory will be created)
.TP
\fI$2\fR (int)
Timeout in seconds to acquire lock (0=non-blocking, -1=wait forever)
.TP
\fI$@\fR (string)
The command and its arguments
.PP
\fBStdout:\fR Command output (if any)
.PP
\fBStderr:\fR Command errors (if any)
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Command completed successfully
.TP
\fB1\fR
Failed to acquire lock within timeout, or invalid arguments
.TP
\fB*\fR
Command's exit code if lock was acquired
.PP
\fBExample:\fR
.RS
.nf
shlib::cmd_locked /tmp/myapp 5 ./deploy.sh      # wait up to 5s for lock
shlib::cmd_locked /tmp/myapp 0 ./critical.sh    # fail immediately if locked
shlib::cmd_locked /tmp/myapp -1 ./process.sh    # wait forever for lock
.fi
.RE
.SS shlib::cmd_retry
.BI "shlib::cmd_retry " "int" " " "int" " " "string"
.PP
Retry a command multiple times with optional delay
.PP
\fBArguments:\fR
.TP
\fI$1\fR (int)
Maximum number of attempts
.TP
\fI$2\fR (int)
Delay in seconds between attempts (0 for no delay)
.TP
\fI$@\fR (string)
The command and its arguments
.PP
\fBStdout:\fR Command output from the successful attempt (if any)
.PP
\fBStderr:\fR Command errors (if any)
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Command succeeded within max attempts
.TP
\fB1\fR
All attempts failed
.PP
\fBExample:\fR
.RS
.nf
shlib::cmd_retry 3 1 curl -f http://example.com   # retry 3 times, 1s delay
shlib::cmd_retry 5 0 test -f /path/to/file        # retry 5 times, no delay
.fi
.RE
.SS shlib::cmd_timeout
.BI "shlib::cmd_timeout " "int" " " "string"
.PP
Run a command with a timeout
.PP
\fBArguments:\fR
.TP
\fI$1\fR (int)
Timeout in seconds
.TP
\fI$@\fR (string)
The command and its arguments
.PP
\fBStdout:\fR Command output (if any)
.PP
\fBStderr:\fR Command errors (if any)
.PP
\fBExit codes:\fR
.TP
\fB0\fR
Command completed successfully within timeout
.TP
\fB124\fR
Command timed out
.TP
\fB*\fR
Command's exit code if it completed before timeout
.PP
\fBExample:\fR
.RS
.nf
shlib::cmd_timeout 5 sleep 2    # succeeds
shlib::cmd_timeout 1 sleep 10   # times out with exit code 124
.fi
.RE

