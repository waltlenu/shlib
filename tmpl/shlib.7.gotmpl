{{ include "src/header.man" -}}
{{ range dirs "src/*/*.bash" }}
.SH {{ basename . | upper }}
{{ range glob (printf "%s/*.bash" .) -}}
{{ shdocTroff . -}}
{{ $man := replace . ".bash" ".man" -}}
{{ if exists $man -}}
{{ include $man -}}
{{ end -}}
{{ end -}}
{{ end -}}
{{ include "src/footer.man" }}
